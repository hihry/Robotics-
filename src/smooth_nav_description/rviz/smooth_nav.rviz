Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Grid
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Normal Cell Count: 0
      Cell Size: 1
      Color: 160; 160; 164
      Plane: XY
      Plane Cell Count: 20
      Reference Frame: <Fixed Frame>

    - Class: rviz_default_plugins/RobotModel
      Name: RobotModel
      Enabled: true
      Description Source: Topic
      Description Topic:
        Value: /robot_description
      Visual Enabled: true
      Collision Enabled: false

    - Class: rviz_default_plugins/Path
      Name: SmoothedPath
      Enabled: true
      Topic:
        Value: /smoothed_path
      Color: 0; 255; 0
      Line Style: Lines
      Buffer Length: 1

    - Class: rviz_default_plugins/Path
      Name: ActualPath
      Enabled: true
      Topic:
        Value: /actual_path
      Color: 0; 0; 255
      Line Style: Lines
      Buffer Length: 1

    - Class: rviz_default_plugins/MarkerArray
      Name: Waypoints
      Enabled: true
      Topic:
        Value: /original_waypoints

    - Class: rviz_default_plugins/Odometry
      Name: Odometry
      Enabled: true
      Topic:
        Value: /odom
      Keep: 100

    - Class: rviz_default_plugins/MarkerArray
      Name: CurvatureMarkers
      Enabled: true
      Topic:
        Value: /curvature_markers

    - Class: rviz_default_plugins/Path
      Name: TrajectoryPath
      Enabled: true
      Topic:
        Value: /trajectory_path
      Color: 255; 165; 0
      Line Style: Lines
      Buffer Length: 1

    - Class: rviz_default_plugins/MarkerArray
      Name: VelocityProfile
      Enabled: true
      Topic:
        Value: /velocity_profile

    - Class: rviz_default_plugins/MarkerArray
      Name: TrajectoryMarkers
      Enabled: true
      Topic:
        Value: /trajectory_markers

    - Class: rviz_default_plugins/MarkerArray
      Name: WaypointMarkers
      Enabled: true
      Topic:
        Value: /waypoint_markers

    - Class: rviz_default_plugins/MarkerArray
      Name: CmdVelArrow
      Enabled: true
      Topic:
        Value: /velocity_command_markers

  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: odom
    Frame Rate: 30

  Name: root
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/FocusCamera

  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/TopDownOrtho
      Name: TopDown
      Near Clip Distance: 0.01
      Scale: 100
      Target Frame: <Fixed Frame>
      X: 1.0
      Y: 0.0
