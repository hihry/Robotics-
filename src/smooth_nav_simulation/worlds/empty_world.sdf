<?xml version="1.0" ?>
<!--
  empty_world.sdf — Clean Gazebo world for trajectory control testing.
  No obstacles — ideal for verifying path tracking accuracy.
-->
<sdf version="1.6">
  <world name="empty_world">
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>
  </world>
</sdf>
